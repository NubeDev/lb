{
  "name": "@lazybones/client-node",
  "version": "0.1.0",
  "private": true,
  "description": "Thin external client for a Lazybones gateway node (auth + ingest + mcp + webhook).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "example": "tsx example.ts",
    "test": "echo 'no unit tests; see README for the live round-trip recipe'"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18"
  }
}
