{
  "schemaVersion": 42,
  "title": "Fleet Overview",
  "description": "Fleet health at a glance",
  "tags": ["ops", "fleet"],
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "timepicker": { "refreshIntervals": ["5s", "10s", "30s"] },
  "timezone": "browser",
  "editable": true,
  "templating": {
    "list": [
      {
        "name": "env",
        "type": "custom",
        "label": "Environment",
        "query": "prod,staging,dev",
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": { "text": "prod", "value": "prod" }
      },
      {
        "name": "region",
        "type": "query",
        "query": "label_values(up, region)",
        "regex": "(?<text>.+) \\((?<value>[A-Z]+)\\)",
        "sort": 1,
        "refresh": 2,
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Throughput",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Requests/sec",
      "gridPos": { "x": 0, "y": 1, "w": 12, "h": 8 },
      "description": "Per-instance request rate",
      "datasource": { "type": "prometheus", "uid": "prom-001" },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        { "refId": "A", "expr": "rate(http_requests_total[5m])", "datasource": { "type": "prometheus", "uid": "prom-001" } },
        { "refId": "B", "expr": "rate(http_errors_total[5m])", "hide": false }
      ],
      "pluginVersion": "10.4.0"
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Error %",
      "gridPos": { "x": 12, "y": 1, "w": 12, "h": 8 },
      "targets": [ { "refId": "A", "expr": "sum(rate(http_errors_total[5m])) / sum(rate(http_requests_total[5m]))" } ],
      "libraryPanel": { "name": "error-pct", "uid": "lib-001" }
    }
  ]
}
