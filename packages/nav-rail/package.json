{
  "name": "@nube/nav-rail",
  "version": "0.1.0",
  "description": "A reusable, data-driven collapsible sidebar (nav rail) for React — shadcn/ui Sidebar vendored as source, self-themed via scoped hsl(var()) tokens, host-overridable. Pass items[] + active/onSelect; header/footer are slots.",
  "license": "UNLICENSED",
  "type": "module",
  "files": ["dist"],
  "main": "./dist/nav-rail.cjs",
  "module": "./dist/nav-rail.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/nav-rail.js",
      "require": "./dist/nav-rail.cjs"
    },
    "./style.css": "./dist/nav-rail.css"
  },
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tooltip": "^1.2.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.453.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "jsdom": "^25.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.0.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^2.0.0"
  }
}
