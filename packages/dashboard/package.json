{
  "name": "@nube/dashboard",
  "version": "0.2.2",
  "description": "The reusable Nube dashboard grid core — a 12-column react-grid-layout host over a persisted cells[] record, with a widget registry (consumers register view renderers), panel-rows section math, an editable/read-only mode, a drag/resize → onLayout persistence seam, and a mobile single-column stack. Pure model + grid host only: the package never fetches, persists, or knows a workspace exists. Self-themed via scoped --lbdg-* tokens, host-overridable.",
  "license": "UNLICENSED",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/dashboard.cjs",
  "module": "./dist/dashboard.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/dashboard.js",
      "require": "./dist/dashboard.cjs"
    },
    "./style.css": "./dist/dashboard.css"
  },
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "lucide-react": "^0.460.0",
    "react-grid-layout": "^1.5.0",
    "react-resizable": "^3.0.5"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/react-grid-layout": "^1.3.5",
    "@vitejs/plugin-react": "^4.2.0",
    "jsdom": "^25.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.9.3",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^2.0.0"
  }
}
