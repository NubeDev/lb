{
  "name": "@nube/ce-wiresheet",
  "version": "0.1.0",
  "description": "Embeddable Control Engine wiresheet editor — connects directly to a CE over REST + binary WebSocket. Drop-in, self-themed, host-overridable.",
  "license": "UNLICENSED",
  "type": "module",
  "files": ["dist"],
  "main": "./dist/ce-wiresheet.cjs",
  "module": "./dist/ce-wiresheet.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/ce-wiresheet.js",
      "require": "./dist/ce-wiresheet.cjs"
    },
    "./style.css": "./dist/ce-wiresheet.css"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && vite build --config vite.lib.config.ts",
    "build:app": "vite build",
    "build:lib": "vite build --config vite.lib.config.ts",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "opencode": "opencode serve --port 4096 --cors http://localhost:5193"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@opencode-ai/sdk": "^1.17.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lint": "^6.9.7",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.1",
    "@typescript/vfs": "^1.6.4",
    "@uiw/react-codemirror": "^4.25.10",
    "@xyflow/react": "^12.11.0",
    "lucide-react": "^0.453.0",
    "typescript": "^5.9.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "jsdom": "^25.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.0.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^1.0.0"
  }
}
