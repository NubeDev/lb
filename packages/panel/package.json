{
  "name": "@nube/panel",
  "version": "0.1.0",
  "description": "A reusable, resizable, dense-and-sectioned side panel for React — the ce-wiresheet InspectPanel look rebuilt on shadcn/ui primitives, self-themed via scoped hsl(var()) tokens, host-overridable. Data-driven via props: pass a header, Sections, dense rows/tables; drag the edge to widen and reveal more option columns.",
  "license": "UNLICENSED",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/panel.cjs",
  "module": "./dist/panel.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/panel.js",
      "require": "./dist/panel.cjs"
    },
    "./style.css": "./dist/panel.css"
  },
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@nube/nav-rail": "workspace:*",
    "@radix-ui/react-dialog": "^1.1.18",
    "@radix-ui/react-slot": "^1.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.460.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.2.0",
    "jsdom": "^25.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^4.0.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^2.0.0"
  }
}
