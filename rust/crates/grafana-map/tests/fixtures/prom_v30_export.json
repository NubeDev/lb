{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    },
    {
      "name": "VAR_JOB",
      "type": "constant",
      "label": "Job",
      "value": "node"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.5.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "schemaVersion": 30,
  "title": "Node Exporter — ${VAR_JOB}",
  "templating": {
    "list": [
      {
        "name": "instance",
        "type": "query",
        "datasource": "${DS_PROMETHEUS}",
        "query": "label_values(up{job=\"${VAR_JOB}\"}, instance)"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "graph",
      "title": "CPU",
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        { "refId": "A", "datasource": "${DS_PROMETHEUS}", "expr": "rate(node_cpu_seconds_total[5m])" }
      ]
    },
    {
      "id": 2,
      "type": "singlestat",
      "title": "Uptime",
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        { "refId": "A", "datasource": "${DS_PROMETHEUS}", "expr": "node_time_seconds - node_boot_time_seconds" }
      ]
    },
    {
      "id": 3,
      "type": "row",
      "title": "Memory",
      "panels": [
        {
          "id": 4,
          "type": "singlestat",
          "title": "Free",
          "datasource": "${DS_PROMETHEUS}",
          "gauge": { "show": true },
          "targets": [
            { "refId": "A", "datasource": "${DS_PROMETHEUS}", "expr": "node_memory_MemFree_bytes" }
          ]
        }
      ]
    }
  ]
}
