// The extension-side copy of the FROZEN widget mount contract (mirror 3 of 3). It MUST stay
// byte-compatible with the host mirror in `ui/src/features/dashboard/builder/federationWidget.ts`
// and the other extensions' `app/contract.ts` copies â€” the three move together, always. It is
// additive; version-gate every version-only field on `ctx.v` (v3: `data`/`fieldConfig`; v4: `theme`).
//
// A PAGE extension (the default scaffold) only needs `MountCtx`/`Bridge`. A WIDGET extension also
// implements `mountWidget` against `WidgetCtx`/`WidgetBridge` and returns a `WidgetHandle`. A DATA
// widget (its `[[widget]]` sets `data = true`) reads `ctx.data` frames + `ctx.fieldConfig` and never
// fetches â€” the shell resolves its `sources[]` under the viewer's grant and hands it the frames.

/** The page mount ctx. */
export interface MountCtx {
  workspace: string;
}

/** The page/widget bridge â€” a leashed `call` (and, for widgets, `watch`). Token never crosses it. */
export interface Bridge {
  call: <T = unknown>(tool: string, args?: Record<string, unknown>) => Promise<T>;
}

/** One resolved field in a frame â€” the `lb-viz` `Frame.fields[]` shape. */
export interface WidgetField {
  name: string;
  type?: string;
  values: unknown[];
}

/** A resolved data frame handed to a v3 data tile via `ctx.data`. Frozen public contract; version it. */
export interface WidgetFrame {
  refId?: string;
  name?: string;
  fields: WidgetField[];
  length?: number;
}

/** The resolved theme tokens (v4) â€” concrete strings for a JS/canvas widget that can't read a CSS var.
 *  Re-delivered via `update(ctx)` on every theme change. A DOM widget re-themes via the cascade. */
export interface WidgetTheme {
  bg: string;
  panel: string;
  fg: string;
  muted: string;
  mutedForeground: string;
  accent: string;
  border: string;
  panel2: string;
  overlay: string;
  accent2: string;
  radius: string;
  fontSans: string;
  fontMono: string;
  surface: string;
  motion: string;
  chart: string[];
}

/** The v4 widget mount ctx (additive over v2/v3). */
export interface WidgetCtx {
  /** Contract version. `4` = frames-in + theme; gate `data`/`fieldConfig` on `v >= 3`, `theme` on `v >= 4`. */
  v: number;
  workspace: string;
  binding: Record<string, unknown>;
  options: Record<string, unknown>;
  vars?: Record<string, unknown>;
  builtins?: Record<string, unknown>;
  timeRange?: { from: number; to: number };
  /** v3 data tiles only: the shell-resolved frames for the cell's `sources[]`. The tile renders these. */
  data?: WidgetFrame[];
  /** v3 data tiles only: the cell's Field-tab `fieldConfig` (units/decimals/thresholds/legend/â€¦). */
  fieldConfig?: unknown;
  /** v4: resolved theme tokens for a JS/canvas widget. DOM widgets re-theme via the cascade and ignore it. */
  theme?: WidgetTheme;
}

/** The widget bridge â€” a data tile needs neither method; it renders `ctx.data`. */
export interface WidgetBridge {
  call: <T = unknown>(tool: string, args?: Record<string, unknown>) => Promise<T>;
  watch?: (tool: string, args: Record<string, unknown>, onEvent: (e: unknown) => void) => () => void;
}

/** A v3 tile MAY return this handle: `update(ctx)` re-renders in place, `teardown()` disposes. A v2
 *  tile returns a bare teardown function (or void) and the shell re-mounts on config change. */
export interface WidgetHandle {
  update?: (ctx: WidgetCtx) => void;
  teardown?: () => void;
}

export type WidgetMount = (
  el: HTMLElement,
  ctx: WidgetCtx,
  bridge: WidgetBridge,
  widgetId: string,
) => void | (() => void) | WidgetHandle;
