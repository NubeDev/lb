[package]
name = "{id}-ext"
version = "0.1.0"
edition = "2021"
license = "MIT OR Apache-2.0"

# This generated crate sits under rust/extensions but is not a workspace member. The local workspace
# stanza prevents Cargo from trying to attach it to the parent Lazybones workspace.
[workspace]

[lib]
crate-type = ["cdylib"]

[dependencies]
wit-bindgen = "0.40"
serde = { version = "1", features = ["derive"] }
serde_json = "1"
# The authoritative WIT lives in the standalone SDK. A `links` crate: its build script exposes the
# WIT path (`DEP_LB_SDK_WIT`) that this crate's `build.rs` feeds to `wit_bindgen::generate!`. It must
# be a NORMAL dep, not a `[build-dependencies]` one: cargo hands `DEP_*` metadata to a build script
# only for its own package's normal dependencies, so as a build-dep `DEP_LB_SDK_WIT` is unset and
# `build.rs` panics — every scaffolded extension is then born unbuildable
# (see debugging/extensions/proof-panel-wit-dep-in-wrong-section.md).
# Pinned to the same tag lb's host pins, so guest and host generate from one contract.
lb-sdk = { git = "https://github.com/NubeDev/lb-ext-sdk", tag = "sdk-v0.2.1" }
