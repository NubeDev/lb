# Generated by Cargo
# will have compiled files and executables
# (anchored: the bare `debug` pattern swallowed ui/src/features/flows/debug/ — a real source dir)
/rust/target/debug/
target

# JavaScript dependencies
node_modules/

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# Local persistent dev state used by `make dev` / `make cloud`: the node store, the dev publisher
# key, and packaged artifacts all live under one root. `.data/` is the pre-`.lazybones/` location,
# kept ignored so an old dev box's store is not accidentally committed.
.lazybones/
.data/

# lazybones daemon working root: its db and every task's worktree live under `.lazy/`.
# Must be ignored — otherwise a task's `git add` stages daemon state into its branch and
# corrupts the merge into `master`.
.lazy/

# `make publish-ext` deploy target: the extension UI bundle the running node serves from
# LB_EXT_UI_DIR. Pure build/deploy output (copied from each ext's ui/dist), never source.
rust/extensions-ui/

# RustRover
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
#.idea/

# Machine-specific cargo tuning (parallel-job caps + host C toolchain / linker paths).
# These point at per-box absolute paths (e.g. the zig shims in ~/.local/bin) and must NOT
# be committed: on CI and other machines the paths don't exist and the linker fails. Each
# dev keeps their own local copy; the repo builds with the default `cc` toolchain.
**/.cargo/config.toml

# AI agent workspaces
.agents/
.claude/
.codex/
.impeccable/

docker/postgres/__pycache__/
clients/python/__pycache__/

# Tauri desktop shell — generated icon variants NOT needed for the bare-executable build.
# `pnpm tauri icon ui/src-tauri/source-icon.png` regenerates the full set from the committed
# source PNG. The desktop build (`tauri build --no-bundle`) only needs the flat icons at the
# root of icons/ (32x32, 64x64, 128x128, 128x128@2x, icon.png/ico/icns) — those ARE tracked.
# The mobile (android/, ios/) + Windows-Store (Square*.png, StoreLogo.png) variants are bulk
# future-work output (mobile + MSI/Store are non-goals for this slice), so they're ignored.
ui/src-tauri/icons/android/
ui/src-tauri/icons/ios/
ui/src-tauri/icons/Square*.png
ui/src-tauri/icons/StoreLogo.png

# Desktop build outputs — the bare-executable build type lands its ELF + CI tarball in
# build/linux/executable/. Both are regenerated by `make linux-executable` / `make artifact`;
# only the dir's README.md is tracked (the `!` line below un-ignores it).
desktop/build/linux/executable/*
!desktop/build/linux/executable/README.md
rust/.pnpm-store/v10/projects/83ddac89125c051d0decf4f112b22160
desktop/build/windows/lazybones-shell.exe
.gitignore
desktop/build/windows/demo-buildings.db
desktop/build/linux/executable/lazybones-shell