# The shell installs STANDALONE, outside the repo pnpm workspace, on purpose: the workspace-root
# `overrides` pin `@types/react` to 18 (the web shell is React 18), while RN 0.86 requires React 19
# and its types. A standalone lockfile keeps both coherent until the web shell moves to React 19 —
# revisit then (recorded in docs/sessions/app/app-shell-session.md). `@nube/app-sdk` still links in
# via the `file:../sdk` dependency, so web and app share one client source regardless.
ignore-workspace=true
