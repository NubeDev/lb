{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["react-native"],
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src", "index.js", "App.tsx"],
  "exclude": ["node_modules"]
}
