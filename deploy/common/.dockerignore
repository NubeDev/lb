# .dockerignore — the whitelist ignore content referenced by EVERY driver (local Docker, CI, Fly's
# `--ignorefile`), so the build context is small and IDENTICAL everywhere (see ../README.md).
# Build context is the repo root. Whitelist approach: deny everything, then allow only what
# deploy/common/Dockerfile's COPY layers need.

**

!rust/**
!ui/**
!packages/**
!docker/postgres/seed.py
!docker/postgres/generators.py
!docker/postgres/inventory.py
!docker/postgres/tags.py
!docker/postgres/sinks_sqlite.py
!docker/postgres/seed-demo-sqlite.sh
!deploy/common/**
!pnpm-workspace.yaml
!pnpm-lock.yaml

# Heavy/irrelevant trees under the allowed roots.
**/target/**
**/node_modules/**
**/.git/**
**/dist/**
**/.turbo/**
**/.pnpm-store/**
**/test-results/**
**/playwright-report/**
rust/extensions/*/target/**
ui/src-tauri/target/**
